"""
Monitoring des pipelines
"""

import logging
import time
from datetime import datetime
from azure.identity import DefaultAzureCredential
from azure.mgmt.datafactory import DataFactoryManagementClient

logger = logging.getLogger(__name__)

class PipelineMonitor:
    """Moniteur de pipelines"""
    
    def __init__(self, subscription_id, resource_group, factory_name):
        credential = DefaultAzureCredential()
        self.client = DataFactoryManagementClient(credential, subscription_id)
        self.resource_group = resource_group
        self.factory_name = factory_name
    
    def trigger_pipeline(self, pipeline_name):
        """Déclencher un pipeline"""
        try:
            logger.info(f"🚀 Déclenchement du pipeline: {pipeline_name}")
            
            run_response = self.client.pipelines.create_run(
                self.resource_group,
                self.factory_name,
                pipeline_name
            )
            
            run_id = run_response.run_id
            logger.info(f"✅ Pipeline déclenché - Run ID: {run_id}")
            
            return run_id
            
        except Exception as e:
            logger.error(f"❌ Erreur: {str(e)}")
            raise
    
    def wait_for_completion(self, run_id, timeout=3600):
        """Attendre la fin du pipeline"""
        logger.info(f"⏳ Attente de la fin du pipeline...")
        
        start_time = time.time()
        
        while time.time() - start_time < timeout:
            run = self.client.pipeline_runs.get(
                self.resource_group,
                self.factory_name,
                run_id
            )
            
            if run.status in ["Succeeded", "Failed", "Cancelled"]:
                logger.info(f"✅ Pipeline terminé - Status: {run.status}")
                return run
            
            logger.info(f"⏳ Status actuel: {run.status}")
            time.sleep(30)
        
        raise Exception("Pipeline timeout")
    
    def get_activity_errors(self, run_id):
        """Obtenir les erreurs des activités"""
        logger.info(f"🔍 Récupération des erreurs...")
        
        activity_runs = self.client.activity_runs.query_by_pipeline_run(
            self.resource_group,
            self.factory_name,
            run_id,
            RunFilterParameters(last_updated_after=datetime.min, last_updated_before=datetime.now())
        )
        
        errors = []
        for activity_run in activity_runs.value:
            if activity_run.status == "Failed":
                errors.append({
                    "activity": activity_run.activity_name,
                    "error": activity_run.error
                })
        
        return errors


def monitor_all_pipelines():
    """Monitorer tous les pipelines"""
    import os
    
    monitor = PipelineMonitor(
        os.getenv("SUBSCRIPTION_ID"),
        "data-rg",
        "data-factory-prod"
    )
    
    pipelines = [
        "CustomerPipeline",
        "SalesPipeline",
        "ProductPipeline"
    ]
    
    for pipeline in pipelines:
        try:
            run_id = monitor.trigger_pipeline(pipeline)
            run = monitor.wait_for_completion(run_id)
            
            if run.status == "Failed":
                errors = monitor.get_activity_errors(run_id)
                logger.error(f"Erreurs détectées: {errors}")
        
        except Exception as e:
            logger.error(f"❌ Erreur pour {pipeline}: {str(e)}")
